{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | grep -qE '\\.(ts|tsx)$' && yarn tsc --noEmit 2>&1 | tail -30 || true",
            "timeout": 60,
            "statusMessage": "Typechecking..."
          }
        ]
      }
    ]
  }
}
